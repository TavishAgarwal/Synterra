# Synthetic Nation - Frontend Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# Backend API URL (your FastAPI server)
VITE_API_BASE_URL=http://localhost:8000

# Mapbox (for city maps - get a free token at mapbox.com)
# Restrict this token to your domain in the Mapbox dashboard.
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# Simulation settings
VITE_DEMO_MODE=true
VITE_MAX_AGENTS=10000

# Do not add API keys for OpenAI, Anthropic, or any LLM provider here.
# Those keys belong in backend/.env only.
