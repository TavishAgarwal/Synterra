# Synthetic Nation - Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# LLM API keys (backend only)
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Simulation configuration
TIER1_AGENT_COUNT=10000
TIER2_AGENT_COUNT=400
TIER3_AGENT_COUNT=100
SIMULATION_DAYS=30

# Database
DATABASE_URL=postgresql://user:dbpass@localhost:5432/synthetic_nation
# For local dev without PostgreSQL:
# DATABASE_URL=sqlite:///./synthetic_nation.db

# Redis
REDIS_URL=redis://localhost:6379

# Server configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true

# CORS (comma-separated allowed origins)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080

# Rate limiting
RATE_LIMIT_SIMULATIONS_PER_MINUTE=5
RATE_LIMIT_QUERIES_PER_MINUTE=30
